{
  "name": "vscode-voice-scribe",
  "displayName": "Voice Scribe",
  "description": "High-quality real-time voice-to-text for VS Code with live rewriting",
  "version": "0.1.0",
  "publisher": "1vecera",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "voice",
    "dictation",
    "speech-to-text",
    "transcription",
    "ai",
    "scribe"
  ],
  "activationEvents": [
    "onCommand:voiceScribe.startRecording",
    "onCommand:voiceScribe.configureApiKey"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "voiceScribe.startRecording",
        "title": "Voice Scribe: Start Recording"
      },
      {
        "command": "voiceScribe.stopRecording",
        "title": "Voice Scribe: Stop Recording"
      },
      {
        "command": "voiceScribe.configureApiKey",
        "title": "Voice Scribe: Configure API Key"
      }
    ],
    "configuration": {
      "title": "Voice Scribe",
      "properties": {
        "voiceScribe.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your ElevenLabs API key for speech-to-text"
        },
        "voiceScribe.enhancement.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI-powered transcription enhancement"
        },
        "voiceScribe.enhancement.model": {
          "type": "string",
          "default": "claude-3-5-sonnet-20241022",
          "description": "Model to use for enhancement (claude-3-5-sonnet-20241022, gpt-4-turbo)"
        },
        "voiceScribe.enhancement.provider": {
          "type": "string",
          "default": "anthropic",
          "enum": [
            "anthropic",
            "openai"
          ],
          "description": "AI provider for enhancement"
        }
      }
    },
    "keybindings": [
      {
        "command": "voiceScribe.startRecording",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus"
      },
      {
        "command": "voiceScribe.stopRecording",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "voiceScribe.recording"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:enhancement": "npm run compile && node -r dotenv/config test_enhancement.ts"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "ws": "^8.14.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/1vecera/vscode-voice-scribe.git"
  },
  "license": "MIT"
}
